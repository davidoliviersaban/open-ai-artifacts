{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-artifacts.local/schemas/artifacts.schema.json",
  "title": "AI Artifacts Playbook",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "packages", "artifacts"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "vendorDir": {
      "$ref": "#/$defs/safePath"
    },
    "reportsDir": {
      "$ref": "#/$defs/safePath"
    },
    "overlaysDir": {
      "$ref": "#/$defs/safePath"
    },
    "riskPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "failOn": {
          "type": "array",
          "items": {
            "enum": ["Low", "Medium", "High"]
          }
        }
      }
    },
    "packages": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "repo", "version"],
        "properties": {
          "type": {
            "const": "git"
          },
          "repo": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "steps"],
        "oneOf": [
          { "required": ["target"], "not": { "required": ["targetDir"] } },
          { "required": ["targetDir"], "not": { "required": ["target"] } }
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "$ref": "#/$defs/safePath"
          },
          "targetDir": {
            "$ref": "#/$defs/safePath"
          },
          "driftPolicy": {
            "type": "object"
          },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "oneOf": [
                { "$ref": "#/$defs/renderStep" },
                { "$ref": "#/$defs/copyStep" },
                { "$ref": "#/$defs/linkStep" }
              ]
            }
          }
        }
      }
    }
  },
  "$defs": {
    "safePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "^/" },
          { "pattern": "(^|/)\\.\\.(/|$)" }
        ]
      }
    },
    "reference": {
      "type": "string",
      "pattern": "^[^:]+:.+"
    },
    "renderStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["render"],
      "properties": {
        "render": {
          "type": "object",
          "additionalProperties": false,
          "required": ["from"],
          "properties": {
            "from": {
              "$ref": "#/$defs/reference"
            },
            "to": {
              "$ref": "#/$defs/safePath"
            },
            "overlays": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/safePath"
              }
            },
            "substitutions": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["from", "to"],
                "properties": {
                  "from": { "type": "string" },
                  "to": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "copyStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["copy"],
      "properties": {
        "copy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["from", "to"],
          "properties": {
            "from": {
              "$ref": "#/$defs/reference"
            },
            "to": {
              "$ref": "#/$defs/safePath"
            }
          }
        }
      }
    },
    "linkStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["link"],
      "properties": {
        "link": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target", "to"],
          "properties": {
            "target": {
              "$ref": "#/$defs/safePath"
            },
            "to": {
              "$ref": "#/$defs/safePath"
            }
          }
        }
      }
    }
  }
}
