{
  "name": "ai-artifacts",
  "projectType": "library",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "find packages/ai-artifacts -name '*.test.js' | xargs node --test"
      }
    },
    "validate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node packages/ai-artifacts/cli.js validate"
      }
    },
    "fetch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node packages/ai-artifacts/cli.js fetch"
      }
    },
    "sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node packages/ai-artifacts/cli.js sync"
      }
    },
    "drift": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node packages/ai-artifacts/cli.js drift"
      }
    },
    "risk": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node packages/ai-artifacts/cli.js risk"
      }
    }
  }
}
