{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "npm install*": "ask",
      "npm run *": "allow",
      "node packages/ai-artifacts/cli.js *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "rm *": "deny",
      "git reset *": "deny",
      "git checkout *": "deny",
      "git clean *": "deny"
    }
  },
  "tool_output": {
    "max_lines": 300,
    "max_bytes": 20000
  }
}
